---
const videos = [
  { id: 'HEa9vzq4g9E', name: 'Avatar 1', subs: '200k Subscribers' },
  { id: '_P64RnHuQEg', name: 'Avatar 2', subs: '200k Subscribers' },
  { id: '-v09L5ENA98', name: 'Avatar 3', subs: '200k Subscribers' },
];
---

<section id="bottom" class="bottom">
  <div class="bottom__inner">
    <div class="bottom__card">
      <div class="bottom__rows">
        {videos.map((v, i) => (
          <div class={`bottom__row ${i % 2 === 1 ? 'bottom__row--reverse' : ''}`}>
            <div class="bottom__video-wrap">
              <div class="bottom__video-panel" aria-hidden="true"></div>
              <div class="bottom__video">
                <iframe
                  src={`https://www.youtube.com/embed/${v.id}`}
                  title={`${v.name} — featured edit`}
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen
                  loading="lazy"
                ></iframe>
              </div>
            </div>

            <div class="bottom__label">
              <p class="bottom__name">{v.name}</p>
              <p class="bottom__subs">{v.subs}</p>
            </div>
          </div>
        ))}
      </div>

      <a
        class="bottom__cta"
        href="https://x.com/mjavfxx"
        target="_blank"
        rel="noopener noreferrer"
      >
        Work With Me
      </a>

      <div class="bottom__footer">
        <img
          class="bottom__signature-mark"
          src="/images/mjav-watermark.png"
          alt="mjav"
          width="78"
          height="78"
          loading="lazy"
        />
        <p class="bottom__signature-sub">The Editor</p>
        <p class="bottom__copyright">Copyright 2025. MJAVFX. All Rights Reserved.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .bottom {
    width: 100%;
    padding: 64px 0 96px;
  }

  .bottom__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
    display: flex;
    justify-content: center;
  }

  .bottom__card {
    position: relative;
    width: 100%;
    max-width: 920px;
    padding: 48px 40px 40px;
    border-radius: 24px;
    background: linear-gradient(180deg, #4A167F 0%, #1B092D 100%);
    box-shadow: 0 4px 50px rgba(0, 0, 0, 0.25);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 56px;
    overflow: hidden;
  }

  .bottom__rows {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .bottom__row {
    position: relative;
    display: flex;
    align-items: center;
    gap: 24px;
  }

  .bottom__row--reverse {
    flex-direction: row-reverse;
  }

  .bottom__video-wrap {
    position: relative;
    width: 100%;
    max-width: 383px;
    flex-shrink: 0;
  }

  /* Angular panel peeking out behind each video frame —
     mirrors the dark overlay shape (--color-bg-panel) from the
     original Figma export, alternating side with the row. */
  .bottom__video-panel {
    position: absolute;
    top: -6%;
    bottom: -6%;
    left: 0;
    right: -4%;
    background: var(--color-bg-panel);
    clip-path: polygon(0% 0%, 60% 0%, 100% 100%, 0% 100%);
    z-index: 0;
  }

  .bottom__row--reverse .bottom__video-panel {
    left: -4%;
    right: 0;
    clip-path: polygon(40% 0%, 100% 0%, 100% 100%, 0% 100%);
  }

  .bottom__video {
    position: relative;
    width: 100%;
    aspect-ratio: 383 / 203;
    border-radius: 20px;
    overflow: hidden;
    background: #000;
    z-index: 1;
  }

  .bottom__video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .bottom__label {
    flex: 1;
    text-align: center;
  }

  .bottom__name {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    line-height: 1.1;
    color: var(--color-white);
  }

  .bottom__subs {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1rem, 2vw, 1.3rem);
    line-height: 1.1;
    color: var(--color-cream);
  }

  .bottom__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 18px 52px;
    border-radius: 999px;
    background-color: var(--color-coral);
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    white-space: nowrap;
    text-decoration: none;
    transition: background-color 0.25s ease, color 0.25s ease, transform 0.15s ease;
  }

  .bottom__cta:hover {
    background-color: var(--color-lime);
    color: #0c1a00;
  }

  .bottom__cta:active {
    transform: scale(0.97);
  }

  .bottom__footer {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: -16px;
  }

  .bottom__signature-mark {
    width: 64px;
    height: auto;
    opacity: 0.85;
  }

  .bottom__signature-sub {
    margin: -6px 0 0;
    font-family: var(--font-body);
    font-size: 0.7rem;
    color: var(--color-cream);
    opacity: 0.6;
  }

  .bottom__copyright {
    margin: 12px 0 0;
    font-family: var(--font-body);
    font-size: 0.65rem;
    color: var(--color-white);
    opacity: 0.5;
  }

  @media (max-width: 640px) {
    .bottom__row,
    .bottom__row--reverse {
      flex-direction: column;
      gap: 16px;
    }

    .bottom__video-panel,
    .bottom__row--reverse .bottom__video-panel {
      left: -3%;
      right: -3%;
      clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%);
    }
  }
</style>

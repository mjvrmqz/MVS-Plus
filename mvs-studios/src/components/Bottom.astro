---
const video = { id: 'HEa9vzq4g9E', name: 'Avatar 1', subs: '200k Subscribers' };
---

<section id="bottom" class="bottom">
  <div class="bottom__inner">
    <div class="bottom__row">
      <div class="bottom__video-wrap">
        <div class="bottom__video-panel" aria-hidden="true"></div>
        <div class="bottom__video">
          <iframe
            src={`https://www.youtube.com/embed/${video.id}`}
            title={`${video.name} — featured edit`}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </div>

      <div class="bottom__label">
        <p class="bottom__name">{video.name}</p>
        <p class="bottom__subs">{video.subs}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .bottom {
    width: 100%;
    background: linear-gradient(180deg, #4A167F 0%, #3B1265 100%);
    padding: 56px 0;
  }

  .bottom__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .bottom__row {
    position: relative;
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .bottom__video-wrap {
    position: relative;
    width: 100%;
    max-width: 383px;
    flex-shrink: 0;
  }

  /* Angular panel peeking out behind the video frame —
     mirrors the dark overlay shape (--color-bg-panel) from the
     original Figma export ("Video 1.svg"). */
  .bottom__video-panel {
    position: absolute;
    top: -6%;
    bottom: -6%;
    left: 0;
    right: -4%;
    background: var(--color-bg-panel);
    clip-path: polygon(0% 0%, 60% 0%, 100% 100%, 0% 100%);
    z-index: 0;
  }

  .bottom__video {
    position: relative;
    width: 100%;
    aspect-ratio: 383 / 203;
    border-radius: 20px;
    overflow: hidden;
    background: #000;
    z-index: 1;
  }

  .bottom__video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .bottom__label {
    flex: 1;
    text-align: center;
  }

  .bottom__name {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    line-height: 1.1;
    color: var(--color-white);
  }

  .bottom__subs {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1rem, 2vw, 1.3rem);
    line-height: 1.1;
    color: var(--color-cream);
  }

  @media (max-width: 640px) {
    .bottom__row {
      flex-direction: column;
      gap: 16px;
    }

    .bottom__video-panel {
      left: -3%;
      right: -3%;
      clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%);
    }
  }
</style>

---
const videos = [
  { id: 'HEa9vzq4g9E', name: 'Avatar 1', subs: '200k Subscribers' },
  { id: '_P64RnHuQEg', name: 'Avatar 2', subs: '200k Subscribers' },
  { id: '-v09L5ENA98', name: 'Avatar 3', subs: '200k Subscribers' },
];
---

<section id="bottom" class="bottom">
  <div class="bottom__card">
    <div class="bottom__rows">
      {videos.map((v, i) => (
        <div class={`bottom__row ${i % 2 === 1 ? 'bottom__row--reverse' : ''}`}>
          <div class="bottom__video">
            <iframe
              src={`https://www.youtube.com/embed/${v.id}`}
              title={`${v.name} — featured edit`}
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
              loading="lazy"
            ></iframe>
          </div>

          <div class="bottom__label">
            <p class="bottom__name">{v.name}</p>
            <p class="bottom__subs">{v.subs}</p>
          </div>
        </div>
      ))}
    </div>

    <a
      class="bottom__cta"
      href="https://x.com/mjavfxx"
      target="_blank"
      rel="noopener noreferrer"
    >
      Work With Me
    </a>

    <div class="bottom__footer">
      <p class="bottom__signature">mjav</p>
      <p class="bottom__signature-sub">The Editor</p>
      <p class="bottom__copyright">Copyright 2025. MJAVFX. All Rights Reserved.</p>
    </div>
  </div>
</section>

<style>
  .bottom {
    width: 100%;
    padding: 64px 0 96px;
    display: flex;
    justify-content: center;
  }

  .bottom__card {
    position: relative;
    width: 100%;
    max-width: 763px;
    margin: 0 32px;
    padding: 48px 32px 40px;
    border-radius: 24px;
    background: linear-gradient(180deg, #4A167F 0%, #1B092D 100%);
    box-shadow: 0 4px 50px rgba(0, 0, 0, 0.25);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 56px;
  }

  .bottom__rows {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .bottom__row {
    position: relative;
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .bottom__row--reverse {
    flex-direction: row-reverse;
  }

  .bottom__video {
    position: relative;
    width: 100%;
    max-width: 383px;
    aspect-ratio: 383 / 203;
    border-radius: 20px;
    overflow: hidden;
    background: #000;
    flex-shrink: 0;
  }

  .bottom__video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .bottom__label {
    flex: 1;
    text-align: center;
  }

  .bottom__name {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    color: var(--color-white);
  }

  .bottom__subs {
    margin: 4px 0 0;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(1rem, 2vw, 1.3rem);
    color: var(--color-cream);
  }

  .bottom__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 18px 52px;
    border-radius: 999px;
    background-color: var(--color-coral);
    color: #fff;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.1rem;
    white-space: nowrap;
    text-decoration: none;
    transition: background-color 0.25s ease, color 0.25s ease, transform 0.15s ease;
  }

  .bottom__cta:hover {
    background-color: var(--color-lime);
    color: #0c1a00;
  }

  .bottom__cta:active {
    transform: scale(0.97);
  }

  .bottom__footer {
    text-align: center;
    margin-top: -16px;
  }

  .bottom__signature {
    margin: 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 600;
    font-size: 1.1rem;
    color: var(--color-cream);
    opacity: 0.7;
  }

  .bottom__signature-sub {
    margin: 0;
    font-family: var(--font-body);
    font-size: 0.7rem;
    color: var(--color-cream);
    opacity: 0.6;
  }

  .bottom__copyright {
    margin: 12px 0 0;
    font-family: var(--font-body);
    font-size: 0.65rem;
    color: var(--color-white);
    opacity: 0.5;
  }

  @media (max-width: 640px) {
    .bottom__row,
    .bottom__row--reverse {
      flex-direction: column;
      gap: 12px;
    }
  }
</style>

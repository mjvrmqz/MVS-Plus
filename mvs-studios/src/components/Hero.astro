---
// Hero.astro
// Source: Home.svg (top ~531px of the 765x747 viewBox — the rest of the
// viewBox is transparent dead space and is not represented here).
//
// Layout mirrors the SVG:
//  - left: black video frame (Video 1 embed)
//  - right: "Trusted By" + avatar pill row (which doubles as an infinite
//    marquee carousel), hero heading, CTA button
//
// Background: linear gradient (#180828 -> #4A167F -> #4F316D) plus an
// angled overlay panel (#1B092D -> #50326E), matching paint0/paint1 in the SVG.

const YT_VIDEO_1 = 'LEzIK0WT4Yk';

// "Trusted By" pills — placeholder count, duplicated once so the marquee
// loop point (translateX -50%) is seamless.
const pillCount = 6;
const pills = [...Array(pillCount * 2)].map((_, i) => i);

// Split heading lines into per-character spans for stagger animation.
const headingLines = ['Hero Text', 'Goes Here'];
const charDelay = 0.04;
const lineStartDelay = [0.1, 0.5];
---

<section id="home" class="hero">
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__bg-gradient"></div>
    <div class="hero__bg-panel"></div>
  </div>

  <div class="hero__content">
    <div class="hero__video">
      <div class="hero__video-frame">
        <iframe
          src={`https://www.youtube.com/embed/${YT_VIDEO_1}`}
          title="Featured work — Video 1"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </div>

    <div class="hero__copy">
      <div class="hero__trusted">
        <span class="hero__trusted-label">Trusted By</span>
        <div class="hero__trusted-carousel" aria-hidden="true">
          <ul class="hero__trusted-track">
            {pills.map((i) => <li class="pill" key={i}></li>)}
          </ul>
        </div>
      </div>

      <h1 class="hero__heading" aria-label={headingLines.join(' ')}>
        {headingLines.map((line, lineIdx) => (
          <span class="hero__heading-line">
            {line.split('').map((char, charIdx) => (
              <span
                class="hero__char"
                style={`animation-delay: ${(lineStartDelay[lineIdx] + charIdx * charDelay).toFixed(3)}s`}
                aria-hidden="true"
              >{char === ' ' ? '\u00A0' : char}</span>
            ))}
          </span>
        ))}
      </h1>

      <a
        class="hero__cta"
        href="https://x.com/mjavfxx"
        target="_blank"
        rel="noopener noreferrer"
      >
        Work With Me
      </a>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    padding: calc(var(--nav-height) + 96px) 0 96px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      165deg,
      var(--color-bg-deep) 0%,
      var(--color-bg-mid) 54%,
      var(--color-bg-soft) 74%
    );
  }

  .hero__bg-panel {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--color-bg-panel) 0%, var(--color-bg-panel-2) 100%);
    clip-path: polygon(0% 68%, 41% 0%, 100% 0%, 100% 100%, 0% 100%);
    opacity: 0.9;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: 48px;
    align-items: center;
  }

  .hero__video-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 20px;
    overflow: hidden;
    background: #000;
  }

  .hero__video-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
  }

  /* ---------- Trusted By ---------- */
  .hero__trusted {
    display: flex !important;
    align-items: center !important;
    gap: 16px !important;
    margin-bottom: 28px !important;
  }

  .hero__trusted-label {
    font-size: 1rem !important;
    color: var(--color-white) !important;
    opacity: 0.85 !important;
    white-space: nowrap !important;
    flex-shrink: 0 !important;
  }

  .hero__trusted-carousel {
    position: relative;
    overflow: hidden;
    width: 160px !important;
    flex-shrink: 0;
    mask-image: linear-gradient(90deg, transparent 0%, black 15%, black 85%, transparent 100%);
    -webkit-mask-image: linear-gradient(90deg, transparent 0%, black 15%, black 85%, transparent 100%);
  }

  .hero__trusted-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: trustedScroll 18s linear infinite;
  }

  .pill {
    flex: 0 0 auto !important;
    width: 36px !important;
    height: 36px !important;
    border-radius: 50% !important;
    background: var(--color-white) !important;
    opacity: 0.45 !important;
    border: 2.5px solid var(--color-bg-mid) !important;
    margin-left: -10px !important;
  }

  .pill:first-child {
    margin-left: 0 !important;
  }

  @keyframes trustedScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__trusted-track { animation: none; }
  }

  /* ---------- Hero heading ---------- */
  .hero__heading {
    font-family: var(--font-display) !important;
    color: var(--color-cream) !important;
    font-size: 4rem !important;
    line-height: 1.05 !important;
    font-weight: 700 !important;
    margin: 0 0 32px 0 !important;
  }

  .hero__heading-line {
    display: block !important;
  }

  .hero__char {
    display: inline-block !important;
    opacity: 0;
    transform: translateY(28px);
    animation: charFadeUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes charFadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__char {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
    }
  }

  /* ---------- CTA button ---------- */
  .hero__cta {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    align-self: flex-start !important;
    padding: 18px 52px !important;
    border-radius: 999px !important;
    background-color: var(--color-coral) !important;
    color: var(--color-white) !important;
    font-weight: 700 !important;
    font-size: 1.1rem !important;
    white-space: nowrap !important;
    transition: background-color 0.25s ease, transform 0.15s ease !important;
    text-decoration: none !important;
  }

  .hero__cta:hover,
  .hero__cta:focus-visible {
    background-color: var(--color-lime) !important;
    color: #0c1a00 !important;
  }

  .hero__cta:active {
    transform: scale(0.97) !important;
  }

  @media (max-width: 860px) {
    .hero__content {
      grid-template-columns: 1fr;
      padding: 0 24px;
    }
    .hero__heading {
      font-size: clamp(2rem, 8vw, 2.75rem) !important;
    }
  }
</style>

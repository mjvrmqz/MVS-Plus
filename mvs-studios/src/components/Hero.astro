---
// Hero.astro
// Source: Home.svg (top ~531px of the 765x747 viewBox — the rest of the
// viewBox is transparent dead space and is not represented here).
//
// Layout mirrors the SVG:
//  - left: black video frame (Video 1 embed)
//  - right: "Trusted By" + avatar pill row (which doubles as an infinite
//    marquee carousel), hero heading, CTA button
//
// Background: linear gradient (#180828 -> #4A167F -> #4F316D) plus an
// angled overlay panel (#1B092D -> #50326E), matching paint0/paint1 in the SVG.

const YT_VIDEO_1 = 'LEzIK0WT4Yk';

// "Trusted By" pills — placeholder count, duplicated once so the marquee
// loop point (translateX -50%) is seamless.
const pillCount = 6;
const pills = [...Array(pillCount * 2)].map((_, i) => i);

// Split heading lines into per-character spans for stagger animation.
// Spaces are rendered as non-breaking so they don't collapse.
const headingLines = ['Hero Text', 'Goes Here'];
const charDelay = 0.04; // seconds between each character
const lineStartDelay = [0.1, 0.5]; // stagger offset per line
---

<section id="home" class="hero">
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__bg-gradient"></div>
    <div class="hero__bg-panel"></div>
  </div>

  <div class="hero__content">
    <div class="hero__video">
      <div class="hero__video-frame">
        <iframe
          src={`https://www.youtube.com/embed/${YT_VIDEO_1}`}
          title="Featured work — Video 1"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </div>

    <div class="hero__copy">
      <div class="hero__trusted">
        <span class="hero__trusted-label">Trusted By</span>
        <div class="hero__trusted-carousel" aria-hidden="true">
          <ul class="hero__trusted-track">
            {pills.map((i) => <li class="pill" key={i}></li>)}
          </ul>
        </div>
      </div>

      <h1 class="hero__heading" aria-label={headingLines.join(' ')}>
        {headingLines.map((line, lineIdx) => (
          <span class="hero__heading-line">
            {line.split('').map((char, charIdx) => (
              <span
                class="hero__char"
                style={`animation-delay: ${(lineStartDelay[lineIdx] + charIdx * charDelay).toFixed(3)}s`}
                aria-hidden="true"
              >{char === ' ' ? '\u00A0' : char}</span>
            ))}
          </span>
        ))}
      </h1>

      <a
        class="hero__cta"
        href="https://x.com/mjavfxx"
        target="_blank"
        rel="noopener noreferrer"
      >
        Work With Me
      </a>
    </div>
  </div>
</section>

<style>
  /* ROOT CAUSE of "background doesn't shrink when zooming out":
     `.hero` was sized with `min-height: 100vh` / `100svh`. Viewport-height
     units are recalculated live against the browser's current effective
     viewport at EVERY zoom level — so as you zoom out, the hero's box kept
     re-stretching itself back out to fill the (now smaller, but still
     100%-of-screen) viewport. The background lives inside that box via
     `inset: 0`, so it kept getting re-stretched along with the box on
     every zoom step. Meanwhile the heading/button/video are sized in
     rem/px and the page's own zoom scaling shrinks them correctly — so
     content visibly shrinks while the vh-driven box (and the background
     painted into it) snaps back to "fill the screen" every time, fighting
     the zoom. Fix: give `.hero` a fixed, content-driven height (no vh
     units at all) so the box — and therefore the background tied to it —
     scales by the exact same browser zoom transform as everything else,
     instead of being recalculated against a live viewport size. */
  .hero {
    position: relative;
    width: 100%;
    padding: calc(var(--nav-height) + 96px) 0 96px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  /* ---------- Background (paint0 / paint1 from Home.svg) ---------- */
  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      165deg,
      var(--color-bg-deep) 0%,
      var(--color-bg-mid) 54%,
      var(--color-bg-soft) 74%
    );
  }

  /* Angled panel mirrors the path M0 510L320 71H746... shape from Home.svg:
     a steep diagonal slice that crosses from the bottom-left up to roughly
     40% across the top edge — much steeper than a generic 0/100 -> 42/0
     polygon, matching the sharper angle visible in the Figma reference. */
  .hero__bg-panel {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--color-bg-panel) 0%, var(--color-bg-panel-2) 100%);
    clip-path: polygon(0% 68%, 41% 0%, 100% 0%, 100% 100%, 0% 100%);
    opacity: 0.9;
  }

  /* ---------- Content ---------- */
  .hero__content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: 48px;
    align-items: center;
  }

  .hero__video-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 20px;
    overflow: hidden;
    background: #000;
  }

  .hero__video-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
  }

  /* ---------- Trusted By ---------- */
  .hero__trusted {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 24px;
  }

  .hero__trusted-label {
    font-size: 1rem;
    color: var(--color-white);
    opacity: 0.85;
    white-space: nowrap;
    flex-shrink: 0;
  }

  /* ---------- Avatar pill carousel (infinite marquee) ---------- */
  .hero__trusted-carousel {
    position: relative;
    overflow: hidden;
    /* Wide enough to show all 6 overlapping pills clearly */
    width: 160px;
    flex-shrink: 0;

    /* Fade-out mask on both edges */
    mask-image: linear-gradient(90deg, transparent 0%, black 15%, black 85%, transparent 100%);
    -webkit-mask-image: linear-gradient(
      90deg,
      transparent 0%,
      black 15%,
      black 85%,
      transparent 100%
    );
  }

  .hero__trusted-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: trustedScroll 18s linear infinite;
  }

  .pill {
    flex: 0 0 auto;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: var(--color-white);
    opacity: 0.45;
    border: 2.5px solid var(--color-bg-mid);
    margin-left: -10px;
  }

  .pill:first-child {
    margin-left: 0;
  }

  @keyframes trustedScroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__trusted-track {
      animation: none;
    }
  }

  /* ---------- Hero heading: per-character fade-up on load ---------- */
  .hero__heading {
    font-family: var(--font-display);
    color: var(--color-cream);
    /* Larger to match Figma's dominant heading proportions */
    font-size: 4rem;
    /* Tight line-height: Figma shows lines nearly touching */
    line-height: 1.05;
    font-weight: 700;
    margin: 0 0 28px 0;
    /* Remove block-level opacity — individual chars handle their own */
  }

  .hero__heading-line {
    display: block;
  }

  /* Each character starts invisible + shifted down, then animates in */
  .hero__char {
    display: inline-block;
    opacity: 0;
    transform: translateY(28px);
    animation: charFadeUp 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes charFadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__char {
      animation: none;
      opacity: 1;
      transform: none;
    }
  }

  /* ---------- CTA button ---------- */
  /* Figma shows a noticeably wide, tall pill — significantly larger than
     the previous 12px/24px padding. Matching proportions from Figma:
     tall enough that the button height feels substantial next to the
     heading, and wide enough that it doesn't look like a chip. */
  .hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    padding: 18px 52px;
    border-radius: 999px;
    background-color: var(--color-coral);
    color: var(--color-white);
    font-weight: 700;
    font-size: 1.1rem;
    white-space: nowrap;
    transition: background-color 0.25s ease, transform 0.15s ease;
  }

  .hero__cta:hover,
  .hero__cta:focus-visible {
    background-color: var(--color-lime);
    color: #0c1a00;
  }

  .hero__cta:active {
    transform: scale(0.97);
  }

  @media (max-width: 860px) {
    .hero__content {
      grid-template-columns: 1fr;
      padding: 0 24px;
    }

    .hero__heading {
      font-size: clamp(2rem, 8vw, 2.75rem);
    }
  }
</style>

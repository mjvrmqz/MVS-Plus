---
// ContactSection.astro
// Placeholder anchor target for the nav's "Contact" link.
// This is intentionally minimal — the full Contact section design
// wasn't part of this build (only Home + Navigation were provided).
---

<section id="contact" class="contact">
  <h2 class="contact__heading">Contact</h2>
  <p class="contact__copy">
    Contact section placeholder — swap this in once the Contact.svg design is ready.
  </p>
</section>

<style>
  .contact {
    width: 100%;
    min-height: 50vh;
    padding: 96px 32px;
    background: var(--color-bg-deep);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .contact__heading {
    font-family: var(--font-display);
    color: var(--color-cream);
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    margin: 0 0 16px;
  }

  .contact__copy {
    color: var(--color-white);
    opacity: 0.7;
    max-width: 420px;
  }
</style>

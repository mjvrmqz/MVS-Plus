---
const creators = [
  { name: 'Avatar 2', subscribers: '200k Subscribers' },
  { name: 'Avatar 2', subscribers: '200k Subscribers' },
  { name: 'Avatar 3', subscribers: '200k Subscribers' },
];
---

<section id="creators" class="creators">
  <div class="creators__inner">
    <h2 class="creators__title">
      <span class="creators__title-line1">Creators I Have</span>
      <span class="creators__title-line2">Worked With</span>
    </h2>

    <div class="creators__grid">
      {creators.map((c) => (
        <div class="creators__card">
          <div class="creators__avatar-wrap">
            <div class="creators__avatar"></div>
            <div class="creators__avatar-badge"></div>
          </div>
          <p class="creators__name">{c.name}</p>
          <p class="creators__subs">{c.subscribers}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .creators {
    width: 100%;
    background: linear-gradient(160deg, #4F3569 0%, #4A167E 60%, #3a0f6e 100%);
    padding: 72px 0 88px;
  }

  .creators__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 56px;
  }

  .creators__title {
    font-family: var(--font-display);
    color: #fff;
    margin: 0;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .creators__title-line1 {
    font-size: clamp(2.8rem, 6vw, 5rem);
    font-weight: 800;
    line-height: 1.05;
    display: block;
  }

  .creators__title-line2 {
    font-size: clamp(2.2rem, 5vw, 4rem);
    font-weight: 400;
    line-height: 1.05;
    display: block;
  }

  .creators__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 48px 32px;
    width: 100%;
  }

  .creators__card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .creators__avatar-wrap {
    position: relative;
    width: 200px;
    height: 200px;
    flex-shrink: 0;
    margin-bottom: 16px;
  }

  .creators__avatar {
    width: 200px;
    height: 200px;
    border-radius: 50%;
    background: #D9D9D9;
  }

  .creators__avatar-badge {
    position: absolute;
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: #fff;
    bottom: -8px;
    right: -8px;
  }

  .creators__name {
    font-family: var(--font-display);
    color: #fff;
    font-size: 1.2rem;
    font-weight: 700;
    margin: 0;
    text-align: center;
  }

  .creators__subs {
    font-family: var(--font-display);
    color: #fff;
    font-size: 1rem;
    font-weight: 700;
    margin: 0;
    text-align: center;
  }

  @media (max-width: 720px) {
    .creators__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

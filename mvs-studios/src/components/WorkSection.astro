---
// WorkSection.astro
// Anchor target for the nav's "Work" link — jumps to the first work video.
import VideoEmbed from './VideoEmbed.astro';

const YT_VIDEO_1 = 'LEzIK0WT4Yk';
const YT_VIDEO_2 = 'Hlg1azra4pU';
---

<section id="work" class="work">
  <h2 class="work__heading">Work</h2>

  <div class="work__videos">
    <VideoEmbed youtubeId={YT_VIDEO_1} title="Featured work — Video 1" />
    <VideoEmbed youtubeId={YT_VIDEO_2} title="Featured work — Video 2" />
  </div>
</section>

<style>
  .work {
    width: 100%;
    padding: 96px 32px;
    background: var(--color-purple-700);
  }

  .work__heading {
    font-family: var(--font-display);
    text-align: center;
    color: var(--color-cream);
    font-size: clamp(1.8rem, 3.5vw, 2.5rem);
    margin: 0 0 48px;
  }

  .work__videos {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: 56px;
  }

  @media (min-width: 900px) {
    .work__videos {
      grid-template-columns: 1fr 1fr;
    }
  }
</style>

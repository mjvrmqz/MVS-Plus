---
// Video 3 — video LEFT, label RIGHT (same layout as Video 1 but mirrored gradient/colors from SVG)
const video = { id: '-v09L5ENA98', name: 'Avatar 3', subs: '200k Subscribers' };

const nameChars = video.name.split('');
const subsChars = video.subs.split('');
const charDelay = 0.04;
const nameStartDelay = 0.1;
const subsStartDelay = nameStartDelay + nameChars.length * charDelay + 0.1;
---

<section class="v3">
  <div class="v3__inner">
    <div class="v3__row">
      <div class="v3__video-wrap reveal">
        <div class="v3__video-panel" aria-hidden="true"></div>
        <div class="v3__video">
          <iframe
            src={`https://www.youtube.com/embed/${video.id}`}
            title={`${video.name} — featured edit`}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </div>

      <div class="v3__label">
        <p class="v3__name" aria-label={video.name}>
          {nameChars.map((char, i) => (
            <span
              class="v3__char reveal"
              style={`--reveal-delay:${(nameStartDelay + i * charDelay).toFixed(3)}s`}
              aria-hidden="true"
            >{char === ' ' ? '\u00A0' : char}</span>
          ))}
        </p>
        <p class="v3__subs" aria-label={video.subs}>
          {subsChars.map((char, i) => (
            <span
              class="v3__char reveal"
              style={`--reveal-delay:${(subsStartDelay + i * charDelay).toFixed(3)}s`}
              aria-hidden="true"
            >{char === ' ' ? '\u00A0' : char}</span>
          ))}
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .v3 {
    width: 100%;
    background: linear-gradient(180deg, #270C40 0%, #1C0A2E 100%);
    padding: 96px 0 112px;
  }

  .v3__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
  }

  .v3__row {
    position: relative;
    display: flex;
    align-items: center;
    gap: 64px;
  }

  /* Video on left — panel peeks from right side of video */
  .v3__video-wrap {
    position: relative;
    width: 100%;
    max-width: 560px;
    flex: 1.1;
    flex-shrink: 0;
  }

  .v3__video-panel {
    position: absolute;
    top: -6%;
    bottom: -6%;
    left: 0;
    right: -4%;
    background: var(--color-bg-panel);
    clip-path: polygon(0% 0%, 60% 0%, 100% 100%, 0% 100%);
    z-index: 0;
  }

  .v3__video {
    position: relative;
    width: 100%;
    aspect-ratio: 383 / 203;
    border-radius: 20px;
    overflow: hidden;
    background: #000;
    z-index: 1;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
  }

  .v3__video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  /* Label on right */
  .v3__label {
    flex: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .v3__name {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 1.05;
    color: var(--color-white);
  }

  .v3__subs {
    margin: 0;
    font-family: 'Mollen', sans-serif;
    font-weight: 400;
    font-size: clamp(1.3rem, 3vw, 2rem);
    line-height: 1.1;
    color: var(--color-cream);
  }

  .v3__char {
    display: inline-block;
  }

  .v3__char.reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0s);
  }

  .v3__char.reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 760px) {
    .v3__row {
      flex-direction: column;
      gap: 32px;
    }

    .v3__video-wrap {
      max-width: 100%;
    }

    .v3__video-panel {
      left: -3%;
      right: -3%;
      clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%);
    }
  }
</style>

---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import Creators from '../components/Creators.astro';
import Video1 from '../components/Video 1.astro';
import Video2 from '../components/Video 2.astro';
import Video3 from '../components/Video 3.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Navigation />
  <main>
    <Hero />
    <Creators />
    <div class="work-sections">
      <Video1 />
      <Video2 />
      <Video3 />
      <Footer />
      <div class="work-arrow-track" aria-hidden="true">
        <img
          src="/images/Arrow.svg"
          alt=""
          class="work-arrow"
          loading="lazy"
        />
      </div>
    </div>
  </main>
</Layout>

<style>
  .work-sections {
    position: relative;
  }

  /* Mirrors each section's .bottom__inner / .v2__inner / .v3__inner
     (max-width: 1400px; margin: 0 auto; padding: 0 48px) so the arrow
     scales and tracks with the actual content column, not the viewport.
     z-index: 1 so it renders ABOVE each section's opaque background
     but BELOW the text labels (which are bumped to z-index: 2) — the
     curve should look like it threads behind the text, not behind the
     entire purple section background. */
  .work-arrow-track {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 48px;
    pointer-events: none;
    z-index: 1;
  }

  /* The arrow's viewBox (499x1078) starts at the very top of Video1.
     --arrow-scale controls how far down the curve reaches WITHOUT
     moving the top start point (top:0 stays fixed; only the height,
     and therefore the bottom end, shrinks/grows). 1 = full track
     height (through Footer). Lower it to pull the tail up closer to
     Video3 / Avatar 3.
     --arrow-shift controls horizontal position: it's added on top of
     the base "right: 48px" anchor — bigger number = arrow moves
     further LEFT (away from the right edge), without affecting the
     top/bottom (vertical) positioning at all. These two are the
     numbers to tweak by hand. */
  .work-arrow {
    --arrow-scale: 0.8;
    --arrow-shift: 160px;
    position: absolute;
    top: 0;
    right: calc(48px + var(--arrow-shift));
    height: calc(var(--arrow-scale) * 100%);
    width: auto;
    pointer-events: none;
  }

  @media (max-width: 760px) {
    .work-arrow-track {
      padding: 0 24px;
    }

    .work-arrow {
      display: none;
    }
  }
</style>

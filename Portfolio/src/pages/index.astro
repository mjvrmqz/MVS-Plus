---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import Creators from '../components/Creators.astro';
import Video1 from '../components/Video 1.astro';
import Video2 from '../components/Video 2.astro';
import Video3 from '../components/Video 3.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Navigation />
  <main>
    <Hero />
    <Creators />
    <div class="work-sections">
      <Video1 />
      <Video2 />
      <Video3 />
      <Footer />
      <div class="work-arrow-track" aria-hidden="true">
        <img
          src="/images/Arrow.svg"
          alt=""
          class="work-arrow"
          loading="lazy"
        />
      </div>
    </div>
  </main>
</Layout>

<style>
  .work-sections {
    position: relative;
  }

  /* Mirrors each section's .bottom__inner / .v2__inner / .v3__inner
     (max-width: 1400px; margin: 0 auto; padding: 0 48px) so the arrow
     scales and tracks with the actual content column, not the viewport. */
  .work-arrow-track {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 100%;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 48px;
    pointer-events: none;
    z-index: 10;
  }

  /* The arrow's viewBox (499x1078) is tall and tuned to span from the
     very top of Video1 down to just above the footer CTA button.
     Height drives the size — no width cap — so it always stretches
     across the FULL combined height of Video1+Video2+Video3+Footer,
     never compressed to a single section's height. */
  .work-arrow {
    position: absolute;
    top: 0;
    right: 48px;
    height: 100%;
    width: auto;
    pointer-events: none;
  }

  @media (max-width: 760px) {
    .work-arrow-track {
      padding: 0 24px;
    }

    .work-arrow {
      display: none;
    }
  }
</style>

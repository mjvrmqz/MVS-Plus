---
import Layout from '../layouts/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Hero from '../components/Hero.astro';
import Creators from '../components/Creators.astro';
import Video1 from '../components/Video 1.astro';
import Video2 from '../components/Video 2.astro';
import Video3 from '../components/Video 3.astro';
import Footer from '../components/Footer.astro';
---

<Layout>
  <Navigation />
  <main>
    <Hero />
    <Creators />
    <div class="work-sections">
      <Video1 />
      <Video2 />
      <Video3 />
      <img
        src="/images/Arrow.svg"
        alt=""
        class="work-arrow"
        aria-hidden="true"
        loading="lazy"
      />
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .work-sections {
    position: relative;
  }

  .work-arrow {
    position: absolute;
    top: 0;
    right: 0;
    width: 38%;
    max-width: 480px;
    min-width: 280px;
    height: auto;
    pointer-events: none;
    z-index: 10;
  }

  @media (max-width: 760px) {
    .work-arrow {
      display: none;
    }
  }
</style>

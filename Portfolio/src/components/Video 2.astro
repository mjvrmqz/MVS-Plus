---
// Video 2 — label LEFT, video RIGHT (panel peeks left from video, mirrored from Video 1)
const video = { id: '_P64RnHuQEg', name: 'Avatar 2', subs: '200k Subscribers' };

const nameChars = video.name.split('');
const subsChars = video.subs.split('');
const charDelay = 0.04;
const nameStartDelay = 0.1;
const subsStartDelay = nameStartDelay + nameChars.length * charDelay + 0.1;
---

<section class="v2">
  <div class="v2__inner">
    <div class="v2__row">
      <div class="v2__label">
        <p class="v2__name" aria-label={video.name}>
          {nameChars.map((char, i) => (
            <span
              class="v2__char reveal"
              style={`--reveal-delay:${(nameStartDelay + i * charDelay).toFixed(3)}s`}
              aria-hidden="true"
            >{char === ' ' ? '\u00A0' : char}</span>
          ))}
        </p>
        <p class="v2__subs" aria-label={video.subs}>
          {subsChars.map((char, i) => (
            <span
              class="v2__char reveal"
              style={`--reveal-delay:${(subsStartDelay + i * charDelay).toFixed(3)}s`}
              aria-hidden="true"
            >{char === ' ' ? '\u00A0' : char}</span>
          ))}
        </p>
      </div>

      <div class="v2__video-wrap reveal">
        <div class="v2__video-panel" aria-hidden="true"></div>
        <div class="v2__video">
          <iframe
            src={`https://www.youtube.com/embed/${video.id}`}
            title={`${video.name} — featured edit`}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
            loading="lazy"
          ></iframe>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .v2 {
    width: 100%;
    background: linear-gradient(180deg, #3F146B 0%, #260C3F 100%);
    padding: 120px 0 140px;
  }

  .v2__inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 48px;
  }

  .v2__row {
    position: relative;
    display: flex;
    align-items: center;
    gap: 80px;
  }

  /* Label on left */
  .v2__label {
    flex: 1;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .v2__name {
    margin: 0;
    font-family: var(--font-display);
    font-weight: 800;
    font-size: clamp(2.8rem, 5.5vw, 5rem);
    line-height: 1.05;
    color: var(--color-white);
  }

  .v2__subs {
    margin: 0;
    font-family: 'Mollen Regular', 'Mollen', sans-serif;
    font-weight: 400;
    font-size: clamp(1.5rem, 3.5vw, 2.4rem);
    line-height: 1.1;
    color: var(--color-cream);
  }

  /* Video on right — panel peeks from the right side */
  .v2__video-wrap {
    position: relative;
    width: 100%;
    max-width: 860px;
    flex: 1.3;
    flex-shrink: 0;
  }

  .v2__video-panel {
    position: absolute;
    top: -6%;
    bottom: -6%;
    left: 4%;
    right: 0;
    background: var(--color-bg-panel);
    clip-path: polygon(0% 100%, 40% 0%, 100% 0%, 100% 100%);
    z-index: 0;
  }

  .v2__video {
    position: relative;
    width: 100%;
    aspect-ratio: 383 / 203;
    border-radius: 20px;
    overflow: hidden;
    background: #000;
    z-index: 1;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
  }

  .v2__video iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .v2__char {
    display: inline-block;
  }

  .v2__char.reveal {
    opacity: 0;
    transform: translateY(28px);
    transition: opacity 0.55s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--reveal-delay, 0s);
  }

  .v2__char.reveal.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (max-width: 760px) {
    .v2 {
      padding: 80px 0 96px;
    }

    .v2__inner {
      padding: 0 24px;
    }

    .v2__row {
      flex-direction: column-reverse;
      gap: 32px;
    }

    .v2__video-wrap {
      max-width: 100%;
    }

    .v2__video-panel {
      left: -3%;
      right: -3%;
      clip-path: polygon(0% 0%, 100% 0%, 100% 100%, 0% 100%);
    }
  }
</style>

---
const YT_VIDEO_1 = 'LEzIK0WT4Yk';

const pillCount = 6;
const pills = [...Array(pillCount * 2)].map((_, i) => i);

const headingLines = ['Hero Text', 'Goes Here'];
const charDelay = 0.04;
const lineStartDelay = [0.1, 0.5];
---

<section id="home" class="hero">
  <div class="hero__bg" aria-hidden="true">
    <div class="hero__bg-gradient"></div>
    <div class="hero__bg-panel"></div>
  </div>

  <div class="hero__content">
    <div class="hero__video">
      <div class="hero__video-frame">
        <iframe
          src={`https://www.youtube.com/embed/${YT_VIDEO_1}`}
          title="Featured work — Video 1"
          frameborder="0"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
          loading="lazy"
        ></iframe>
      </div>
    </div>

    <div class="hero__copy">
      <div class="hero__trusted" style="display:flex;align-items:center;gap:16px;margin-bottom:28px;padding-left:clamp(0px,10vw,96px);">
        <span class="hero__trusted-label" style="font-size:1rem;color:#fff;opacity:0.85;white-space:nowrap;flex-shrink:0;">Trusted By</span>
        <div class="hero__trusted-carousel" aria-hidden="true" style="position:relative;overflow:hidden;width:160px;flex-shrink:0;mask-image:linear-gradient(90deg,transparent 0%,black 15%,black 85%,transparent 100%);-webkit-mask-image:linear-gradient(90deg,transparent 0%,black 15%,black 85%,transparent 100%);">
          <ul class="hero__trusted-track">
            {pills.map((i) => <li class="pill" key={i}></li>)}
          </ul>
        </div>
      </div>

      <h1 class="hero__heading" aria-label={headingLines.join(' ')} style="font-family:var(--font-display);color:#F5E9C6;font-size:4rem;line-height:1.05;font-weight:700;margin:0 0 32px 0;">
        {headingLines.map((line, lineIdx) => (
          <span class="hero__heading-line" style="display:block;">
            {line.split('').map((char, charIdx) => (
              <span
                class="hero__char"
                style={`display:inline-block;opacity:0;transform:translateY(28px);animation:charFadeUp 0.55s cubic-bezier(0.22,1,0.36,1) forwards;animation-delay:${(lineStartDelay[lineIdx] + charIdx * charDelay).toFixed(3)}s`}
                aria-hidden="true"
              >{char === ' ' ? '\u00A0' : char}</span>
            ))}
          </span>
        ))}
      </h1>

      <div style="display:flex;justify-content:center;margin-top:-8px;padding-right:clamp(0px,2vw,24px);">
        <a
          class="hero__cta"
          href="https://x.com/mjavfxx"
          target="_blank"
          rel="noopener noreferrer"
          style="display:inline-flex;align-items:center;justify-content:center;padding:18px 52px;border-radius:999px;background-color:#FF6B6B;color:#fff;font-weight:700;font-size:1.1rem;white-space:nowrap;text-decoration:none;transition:background-color 0.25s ease,transform 0.15s ease;"
        >
          Work With Me
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    width: 100%;
    padding: calc(var(--nav-height) + 96px) 0 96px;
    overflow: hidden;
    display: flex;
    align-items: center;
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__bg-gradient {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      165deg,
      var(--color-bg-deep) 0%,
      var(--color-bg-mid) 54%,
      var(--color-bg-soft) 74%
    );
  }

  .hero__bg-panel {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, var(--color-bg-panel) 0%, var(--color-bg-panel-2) 100%);
    clip-path: polygon(0% 68%, 41% 0%, 100% 0%, 100% 100%, 0% 100%);
    opacity: 0.9;
  }

  .hero__content {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 32px;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 1fr);
    gap: 48px;
    align-items: center;
  }

  .hero__video-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 20px;
    overflow: hidden;
    background: #000;
  }

  .hero__video-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  .hero__copy {
    display: flex;
    flex-direction: column;
    gap: 0;
    min-width: 0;
  }

  .hero__trusted-track {
    display: flex;
    align-items: center;
    width: max-content;
    animation: trustedScroll 18s linear infinite;
  }

  .pill {
    flex: 0 0 auto;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: #fff;
    opacity: 0.45;
    border: 2.5px solid var(--color-bg-mid);
    margin-left: -10px;
  }

  .pill:first-child {
    margin-left: 0;
  }

  @keyframes trustedScroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @keyframes charFadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hero__cta:hover {
    background-color: var(--color-lime) !important;
    color: #0c1a00 !important;
  }

  .hero__cta:active {
    transform: scale(0.97) !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__trusted-track { animation: none; }
  }

  @media (max-width: 860px) {
    .hero__content {
      grid-template-columns: 1fr;
      padding: 0 24px;
    }
  }
</style>

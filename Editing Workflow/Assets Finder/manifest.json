{
  "manifest_version": 3,
  "name": "Full Power Extension",
  "version": "1.0",
  "permissions": [
    "tabs",
    "tabGroups",
    "bookmarks",
    "downloads",
    "storage",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_title": "Full Power"
  }
}
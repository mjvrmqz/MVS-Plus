---
// Nav.astro
// Sticky nav bar that stays fixed on scroll with a blurred backdrop.
// Links scroll to: #home, #avatars, #work, #contact
import NavSvg from '../assets/svg-segments/nav.svg?raw';
---

<header class="site-nav">
  <div class="site-nav__bg" set:html={NavSvg} aria-hidden="true" />
  <nav class="site-nav__links">
    <a href="#home" class="site-nav__link">Home</a>
    <a href="#avatars" class="site-nav__link">Creators</a>
    <a href="#work" class="site-nav__link">Work</a>
    <a href="#contact" class="site-nav__link">Contact</a>
  </nav>
</header>

<style>
  .site-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    height: 55px;
    max-width: 863px;
    margin: 0 auto;

    /* Blurry sticky nav, per interactive notes */
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    background: rgba(29, 9, 49, 0.55);
  }

  .site-nav__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    opacity: 0.4; /* the SVG art is decorative texture under the real links below */
    pointer-events: none;
  }

  .site-nav__bg :global(svg) {
    width: 100%;
    height: 100%;
  }

  .site-nav__links {
    position: relative;
    z-index: 1;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: clamp(1.5rem, 5vw, 3rem);
  }

  .site-nav__link {
    font-size: 0.95rem;
    font-weight: 600;
    color: #fff;
    opacity: 0.9;
    transition: opacity 0.2s ease;
  }

  .site-nav__link:hover,
  .site-nav__link:focus-visible {
    opacity: 1;
  }
</style>

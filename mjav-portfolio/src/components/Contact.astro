---
// Contact.astro
import ScrollReveal from './ScrollReveal.astro';
---

<section id="contact" class="contact section-wrap">
  <div class="content-layer contact__content">
    <ScrollReveal as="h2" class="contact__heading">
      JOIN ME ON<br />a call together
    </ScrollReveal>

    <a
      href="https://x.com/mjavfxx"
      target="_blank"
      rel="noopener noreferrer"
      class="cta-button contact__cta"
    >
      Work With Me
    </a>

    <footer class="contact__footer">
      <p class="contact__logo">mjav <span>The Editor</span></p>
      <p class="contact__copyright">Copyright 2025. MJAVFX - All Rights Reserved</p>
    </footer>
  </div>
</section>

<style>
  .contact {
    position: relative;
    min-height: 591px;
    background: #1d0931;
    padding: 4rem 1.5rem 2.5rem;
  }

  .contact__content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .contact__heading {
    font-size: clamp(1.8rem, 5vw, 2.6rem);
    font-weight: 700;
    line-height: 1.15;
    color: #fff;
    margin-bottom: 2rem;
  }

  .contact__cta {
    margin-bottom: 4rem;
  }

  .contact__footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .contact__logo {
    font-family: 'Mollen', cursive;
    font-size: 1.4rem;
    color: var(--color-cream);
  }

  .contact__logo span {
    display: block;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #fff;
    opacity: 0.7;
  }

  .contact__copyright {
    font-size: 0.7rem;
    color: #fff;
    opacity: 0.6;
  }
</style>

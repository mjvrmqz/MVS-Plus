---
// ScrollReveal.astro
// Wrap any block of content in this component to apply the
// "fade in slowly and move up" animation when it scrolls into view.
//
// Usage:
//   <ScrollReveal><h1>Hero Text</h1></ScrollReveal>
//   <ScrollReveal stagger={1}><div>Avatar 1</div></ScrollReveal>
//
// `stagger` (0-3) adds a transition-delay so groups of siblings
// (e.g. 3 avatar cards) animate in sequence rather than all at once.

interface Props {
  stagger?: 0 | 1 | 2 | 3;
  as?: string;
  class?: string;
}

const { stagger = 0, as: Tag = 'div', class: className = '' } = Astro.props;
---

<Tag class={`fade-in-up ${className}`} data-stagger={stagger || undefined}>
  <slot />
</Tag>

<script>
  // Runs once per page load; observes every .fade-in-up element currently
  // in the DOM. Astro components render their <script> once per unique
  // script body, so this is safe to include in every ScrollReveal instance.
  function initScrollReveal() {
    const targets = document.querySelectorAll('.fade-in-up:not(.is-visible)');
    if (!targets.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.15, rootMargin: '0px 0px -40px 0px' }
    );

    targets.forEach((el) => observer.observe(el));
  }

  // Astro view-transitions friendly: re-init on both initial load and
  // any subsequent client-side navigation.
  document.addEventListener('astro:page-load', initScrollReveal);
</script>

---
// index.astro — single-page layout
// The full mjavfx.svg is the visual backbone at exactly 863px wide.
// All interactive elements (nav links, iframes, CTA buttons) are
// absolutely positioned on top at their Figma pixel coordinates.
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=863" />
  <meta name="description" content="MJAVFX — The Editor" />
  <title>MJAVFX — The Editor</title>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html, body {
      background: #1E1E1E;
      min-height: 100vh;
    }

    /* Centre the 863px canvas on any screen */
    .canvas {
      position: relative;
      width: 863px;
      margin: 0 auto;
    }

    /* Full-page SVG background — exactly matches Figma canvas */
    .canvas__svg {
      display: block;
      width: 863px;
      height: auto;
    }

    /* All overlay elements share this base */
    .overlay {
      position: absolute;
      left: 0;
      top: 0;
      width: 100%;
      pointer-events: none; /* children opt-in below */
    }

    /* ── NAV ── */
    .nav {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 55px;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 80px;
      z-index: 10;
      /* sticky via JS below */
      background: rgba(29, 9, 49, 0.55);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
    }
    .nav.is-sticky {
      position: fixed;
      top: 0;
      width: 863px;
    }
    .nav a {
      color: #fff;
      text-decoration: none;
      font-size: 15px;
      opacity: 0.9;
      pointer-events: all;
    }
    .nav a:hover { opacity: 1; }

    /* ── HERO CTA ── */
    .cta-home {
      position: absolute;
      /* CTA pill centre in Figma: x≈316, y≈290, w≈263, h≈54 */
      top: 290px;
      left: 316px;
      width: 263px;
      height: 54px;
      border-radius: 999px;
      background: transparent;
      pointer-events: all;
      cursor: pointer;
      text-decoration: none;
      display: block;
    }
    .cta-home:hover ~ .cta-home-glow,
    .cta-home:hover { outline: none; }

    /* We overlay a lime-green tint on hover rather than re-rendering the SVG path */
    .cta-btn {
      position: absolute;
      border-radius: 999px;
      border: none;
      cursor: pointer;
      pointer-events: all;
      background: transparent;
      transition: background 0.2s ease;
      text-decoration: none;
      display: flex;
      align-items: center;
      justify-content: center;
      color: transparent; /* text is in the SVG */
      font-size: 0;
    }
    .cta-btn:hover {
      background: rgba(198, 255, 61, 0.35); /* lime-green overlay */
    }
    .cta-btn:active {
      background: rgba(198, 255, 61, 0.55);
    }

    /* ── YOUTUBE IFRAMES ── */
    .yt {
      position: absolute;
      border-radius: 20px;
      overflow: hidden;
      pointer-events: all;
      background: #000;
    }
    .yt iframe {
      width: 100%;
      height: 100%;
      border: 0;
      display: block;
    }

    /* ── FADE-IN-UP ── */
    .fade {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.8s ease, transform 0.8s ease;
    }
    .fade.visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Scroll anchors sit 55px above section so nav doesn't cover content */
    .anchor {
      position: absolute;
      top: -55px;
      left: 0;
      width: 1px;
      height: 1px;
      pointer-events: none;
    }
  </style>
</head>
<body>

  <!-- Sticky nav rendered on top of everything -->
  <nav class="nav" id="site-nav">
    <a href="#home">Home</a>
    <a href="#avatars">Creators</a>
    <a href="#work">Work</a>
    <a href="#contact">Contact</a>
  </nav>

  <div class="canvas">

    <!-- ═══════════════════════════════════════════════
         FULL-PAGE SVG — rendered inline at build time
         by the prebuild script; this is your entire
         Figma design at native 863×2351 resolution.
         ═══════════════════════════════════════════════ -->
    <img
      src="/site-bg.svg"
      alt=""
      aria-hidden="true"
      class="canvas__svg"
      width="863"
      height="2351"
    />

    <!-- ── SECTION ANCHORS ── -->
    <span id="home"  class="anchor" style="top: 55px"></span>
    <span id="avatars" class="anchor" style="top: 614px"></span>
    <span id="work"  class="anchor" style="top: 747px"></span>
    <span id="contact" class="anchor" style="top: 1760px"></span>

    <!-- ── HOME: CTA button ("Work With Me") ── -->
    <!-- Figma: pill at x=316,y=290 w=263 h=54 -->
    <a
      href="https://x.com/mjavfxx"
      target="_blank"
      rel="noopener noreferrer"
      class="cta-btn"
      style="top:290px; left:316px; width:263px; height:54px;"
      aria-label="Work With Me"
    ></a>

    <!-- ── HOME: Video 1 (left box) ── -->
    <!-- Figma rect: x=88,y=372 w=283 h=145 -->
    <div class="yt" style="top:372px; left:88px; width:283px; height:159px;">
      <iframe
        src="https://www.youtube.com/embed/LEzIK0WT4Yk"
        title="Video 1"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>

    <!-- ── HOME: Video 2 (right box) ── -->
    <!-- Figma rect: x=499,y=372 w=283 h=145 -->
    <div class="yt" style="top:372px; left:499px; width:283px; height:159px;">
      <iframe
        src="https://www.youtube.com/embed/Hlg1azra4pU"
        title="Video 2"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>

    <!-- ── WORK SHOWCASE: Video 1 (Avatar 1, left) ── -->
    <!-- Figma: left box roughly x=50,y=1045 w=383 h=203 -->
    <div class="yt fade" style="top:1045px; left:50px; width:383px; height:215px;">
      <iframe
        src="https://www.youtube.com/embed/HEa9vzq4g9E"
        title="Work Video 1"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>

    <!-- ── WORK SHOWCASE: Video 2 (Avatar 2, right) ── -->
    <!-- Figma: right box roughly x=432,y=1377 w=383 h=203 -->
    <div class="yt fade" style="top:1377px; left:432px; width:383px; height:215px;">
      <iframe
        src="https://www.youtube.com/embed/_P64RnHuQEg"
        title="Work Video 2"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>

    <!-- ── WORK SHOWCASE: Video 3 (Avatar 3, left) ── -->
    <!-- Figma: left box roughly x=50,y=1709 w=383 h=203 -->
    <div class="yt fade" style="top:1506px; left:50px; width:383px; height:215px;">
      <iframe
        src="https://www.youtube.com/embed/-v09L5ENA98"
        title="Work Video 3"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>
    </div>

    <!-- ── CONTACT: CTA button ("Work With Me") ── -->
    <!-- Figma: pill at x=305,y=1960 w=255 h=54 -->
    <a
      href="https://x.com/mjavfxx"
      target="_blank"
      rel="noopener noreferrer"
      class="cta-btn"
      style="top:1960px; left:305px; width:255px; height:54px;"
      aria-label="Work With Me"
    ></a>

  </div><!-- /.canvas -->

  <script>
    // ── STICKY NAV ──
    const nav = document.getElementById('site-nav');
    const canvas = document.querySelector('.canvas');
    function onScroll() {
      if (window.scrollY > 0) {
        nav.classList.add('is-sticky');
        // push canvas down so content isn't hidden under sticky nav
        canvas.style.paddingTop = '55px';
      } else {
        nav.classList.remove('is-sticky');
        canvas.style.paddingTop = '0';
      }
    }
    window.addEventListener('scroll', onScroll, { passive: true });

    // ── FADE-IN-UP on scroll ──
    const fades = document.querySelectorAll('.fade');
    const io = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); io.unobserve(e.target); } });
    }, { threshold: 0.15 });
    fades.forEach(el => io.observe(el));

    // ── SMOOTH SCROLL for nav anchors ──
    document.querySelectorAll('.nav a[href^="#"]').forEach(link => {
      link.addEventListener('click', e => {
        e.preventDefault();
        const target = document.getElementById(link.getAttribute('href').slice(1));
        if (target) target.scrollIntoView({ behavior: 'smooth' });
      });
    });
  </script>

</body>
</html>
